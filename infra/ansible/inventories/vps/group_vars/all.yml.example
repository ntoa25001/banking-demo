environment: vps-dev
server_name: banking-lab
public_ip: 194.233.85.69

repo_url: "https://github.com/ntoa25001/banking-demo.git"
repo_branch: "main"
repo_path_on_server: "/opt/banking-demo"

k3s_version: "v1.34.6+k3s1"
kubeconfig_path: "/etc/rancher/k3s/k3s.yaml"

argocd_namespace: "argocd"
argocd_app_name: "banking-demo-phase4"
argocd_project_file: "/opt/banking-demo/phase2-helm-chart/argocd/project-phase4.yaml"
argocd_application_file: "/opt/banking-demo/phase2-helm-chart/argocd/application-phase4.yaml"

banking_namespace: "banking"
monitoring_namespace: "monitoring"
keda_namespace: "keda"

enable_argocd: true
enable_monitoring: true
enable_phase4_bootstrap: true

ingress_host: "npd-banking.co"
